# Copy to `.env` and fill in one (or both) of the credentials below.
# `just` loads this file automatically (`set dotenv-load := true` in justfile).

# --- OAuth subscription credential --------------------------------------------
# Generate with: `claude setup-token` (runs an interactive browser flow)
# Only for YOUR OWN individual use. Do NOT ship a product on this token.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-REPLACE_ME

# --- API key credential -------------------------------------------------------
# Create at https://console.anthropic.com/ → Settings → API Keys
# Use this for anything other people will interact with.
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
